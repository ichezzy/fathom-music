{
  "name": "tavernloops",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Music, ambience and sound-effects controller for tabletop RPG game masters.",
  "author": "ichezzy",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "electron:start": "wait-on tcp:127.0.0.1:5173 && electron .",
    "electron:dev": "concurrently -k -n vite,electron \"npm:dev\" \"npm:electron:start\"",
    "dist": "npm run build && electron-builder --win nsis",
    "release": "npm run build && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/youtube": "^0.1.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.ichezzy.tavernloops",
    "productName": "TavernLoops",
    "files": ["dist/**", "electron/**"],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ichezzy",
        "repo": "tavernloops",
        "releaseType": "release"
      }
    ]
  }
}
